# ============================
# Whale Tracker V2 Configuration
# ============================
# Copy this file to .env and fill in the values

# Database (required for engine service)
DATABASE_URL=postgresql://whale:whale_secret@localhost:5432/whale_tracker
REDIS_URL=redis://localhost:6379/0

# Exchange API Keys (Binance) — optional, only needed for trading
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Exchange API Keys (OKX) — optional
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=

# Exchange API Keys (Bybit) — optional
BYBIT_API_KEY=
BYBIT_API_SECRET=

# BFF Server
BFF_PORT=3001
ENGINE_URL=http://localhost:8000

# CORS — comma-separated list of allowed origins
# For local development:
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
# For production (replace with your actual domain):
# CORS_ORIGINS=https://yourdomain.com,https://api.yourdomain.com

# Frontend
# For local development:
NEXT_PUBLIC_BFF_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001/ws
# For production (replace with your actual domain):
# NEXT_PUBLIC_BFF_URL=https://api.yourdomain.com
# NEXT_PUBLIC_WS_URL=wss://api.yourdomain.com/ws
